# ── LLM providers (at least one required) ────────────────────────────────────
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
HF_TOKEN=
NVIDIA_API_KEY=

# ── Web search ────────────────────────────────────────────────────────────────
# Tinyfish — used by the agent for live docs, CVE details, package info
TINYFISH_API_KEY=

# ── Gateway ───────────────────────────────────────────────────────────────────
GATEWAY_PORT=3001
NEXT_PUBLIC_GATEWAY_URL=http://localhost:3001

# ── Scan result storage ───────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Payments (DoDo — already wired) ──────────────────────────────────────────
DODO_API_KEY=
DODO_PRODUCT_ID=

# ── Model overrides (optional) ────────────────────────────────────────────────
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# GEMINI_MODEL=gemini-2.5-flash
# GROQ_MODEL=llama-3.3-70b-versatile
