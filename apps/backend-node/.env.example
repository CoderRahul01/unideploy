# ── Server ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Upstash Redis (REST API) ────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# ── InsForge (persistence) ──────────────────────────────────────────────────────
INSFORGE_BASE_URL=https://your-insforge-instance.com
INSFORGE_API_KEY=your-insforge-api-key
INSFORGE_PROJECT_ID=your-project-id

# ── Payments ────────────────────────────────────────────────────────────────────
DODO_PAYMENTS_API_KEY=your-dodo-api-key
DODO_WEBHOOK_SECRET=your-dodo-webhook-secret

# Dodo checkout link IDs (from Dodo dashboard)
DODO_CHECKOUT_BUILDER_MONTHLY=link_id_here
DODO_CHECKOUT_BUILDER_ANNUAL=link_id_here
DODO_CHECKOUT_PRO_MONTHLY=link_id_here
DODO_CHECKOUT_PRO_ANNUAL=link_id_here
DODO_CHECKOUT_ENTERPRISE_MONTHLY=link_id_here
DODO_CHECKOUT_ENTERPRISE_ANNUAL=link_id_here

# Optional Razorpay (for Indian users)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── URLs ────────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://app.unideploy.in
