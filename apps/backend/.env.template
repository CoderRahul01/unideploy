# ─── App ───────────────────────────────────────────────────
APP_ENV=production
BASE_URL=https://api.unideploy.in
FRONTEND_URL=https://www.unideploy.in
ALLOWED_ORIGINS=https://www.unideploy.in,https://unideploy.vercel.app

# ─── Session ───────────────────────────────────────────────
SESSION_EXPIRY_MINUTES=10
WEBSOCKET_MAX_CONNECTIONS=100

# ─── Google Cloud / Gemini ADK ─────────────────────────────
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GEMINI_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=/secrets/sa-key.json

# ─── InsForge (Database + Auth) ────────────────────────────
INSFORGE_PROJECT_ID=
INSFORGE_API_KEY=
INSFORGE_BASE_URL=https://api.insforge.dev

# ─── Composio (Tool actions — GitHub, Sentry, Slack) ───────
COMPOSIO_API_KEY=

# ─── Dodo Payments ─────────────────────────────────────────
DODO_API_KEY=
DODO_WEBHOOK_SECRET=

# ─── Supermemory ───────────────────────────────────────────
SUPERMEMORY_API_KEY=

# ─── AutoSend (Email) ──────────────────────────────────────
AUTOSEND_API_KEY=
