# UniDeploy API — Environment Variables

# Required
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
DATABASE_URL=postgresql://user:password@host:5432/unideploy

# Google Gemini (Agent Platform)
GOOGLE_CLOUD_PROJECT=
GEMINI_API_KEY=your-gemini-api-key

# Composio (Tool Actions)
COMPOSIO_API_KEY=your-composio-api-key

# Dodo Payments (Billing)
DODO_PAYMENTS_API_KEY=your-dodo-api-key
DODO_WEBHOOK_SECRET=your-webhook-secret

# Supermemory (Project Memory)
SUPERMEMORY_API_KEY=your-supermemory-key

# AutoSend (Email)
AUTOSEND_API_KEY=your-autosend-key

# E2B (Build Sandbox)
E2B_API_KEY=your-e2b-key

# Clerk (Auth)
CLERK_SECRET_KEY=your-clerk-secret

# Session Config
SESSION_EXPIRY_MINUTES=10
WEBSOCKET_MAX_CONNECTIONS=100

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://unideploy.in

# InsForge (database + auth + storage)
INSFORGE_PROJECT_ID=
INSFORGE_API_KEY=
INSFORGE_BASE_URL=https://api.insforge.dev
