{
  "name": "@unideploy/cli",
  "version": "0.1.0",
  "description": "Production-readiness agent for vibe-coded apps — Pi agent harness",
  "type": "module",
  "bin": {
    "unideploy": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/cli.js",
    "build:dmg": "bash scripts/build-dmg.sh",
    "typecheck": "tsc --noEmit",
    "dev": "npx tsx src/cli.ts"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "0.79.3",
    "@earendil-works/pi-ai": "0.79.3",
    "dotenv": "16.4.7",
    "typebox": "1.1.38"
  },
  "devDependencies": {
    "pkg": "^5.8.1",
    "tsx": "4.19.4",
    "typescript": "5.8.3"
  },
  "optionalDependencies": {
    "appdmg": "^0.6.6"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
